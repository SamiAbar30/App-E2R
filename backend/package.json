{
  "name": "tfm-easy-to-read-backend",
  "version": "2.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "tsc && node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "jest",
    "test:unit": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js tests/unit --testMatch \"**/*.test.js\" --coverage=false",
    "lint": "tsc --noEmit",
    "benchmark:ocr": "tsx scripts/ocr-benchmark.ts",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@google-cloud/vision": "^4.3.2",
    "@techstark/opencv-js": "4.12.0-release.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "franc": "^6.2.0",
    "franc-min": "^6.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.4",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "nock": "^14.0.15",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.10",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5"
  }
}
